  "schema": {
    "intent": "record|find|chat",
    "task": {
      "record": {
        "memory": "",
        "notes": ""
      },
      "find": {
        "query": "",
        "mode": "item|list|property"
      },
      "search": {
        "query": ""
      }
    },
    "tool": "remember_add|remember_find|remember_list|null",
