+def _rrf_score(fts_rank: int | None = None, vector_rank: int | None = None, k: int = 60) -> float:
+    """Reciprocal Rank Fusion 分数计算"""
+    score = 0.0
+    if fts_rank is not None:
+        score += 1.0 / (k + fts_rank)
+    if vector_rank is not None:
+        score += 1.0 / (k + vector_rank)
+    return score
+
